# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

# Read ASC credentials from Secrets.xcconfig
secrets = {}
File.readlines("../Configuration/Secrets.xcconfig").each do |line|
  next if line.strip.start_with?("//") || line.strip.empty?
  key, value = line.split("=", 2).map(&:strip)
  secrets[key] = value if key && value
end

api_key = app_store_connect_api_key(
  key_id: secrets["ASC_KEY_ID"],
  issuer_id: secrets["ASC_ISSUER_ID"],
  key_filepath: "fastlane/AuthKey_#{secrets['ASC_KEY_ID']}.p8"
)

lane :tests do
  run_tests(
    scheme: "Listen anonymously Ext"
  )
end

platform :ios do
  desc "Run tests"
  lane :all_tests do
    run_tests(
      scheme: "Listen anonymously Ext",
      clean: true,
      code_coverage: true,
      result_bundle: true,
      output_directory: "./fastlane/test_output"
    )
  end

  desc "Run all tests with code coverage"
  lane :all_coverage do
    run_tests(
      scheme: "Listen-anonymously",
      clean: true,
      code_coverage: true,
      result_bundle: true,
      output_directory: "./fastlane/test_output"
    )
  end

  desc "Build the app for App Store"
  lane :build do
    Dir.chdir("..") do
      sh "tuist generate --no-open"
    end

    build_app(
      scheme: "Listen-anonymously",
      export_method: "app-store",
      output_directory: "./fastlane/build_output",
      xcargs: "-allowProvisioningUpdates"
    )
  end

  desc "Build and upload to App Store Connect"
  lane :release do
    Dir.chdir("..") do
      sh "tuist generate --no-open"
    end

    build_app(
      scheme: "Listen-anonymously",
      export_method: "app-store",
      output_directory: "./fastlane/build_output",
      xcargs: "-allowProvisioningUpdates"
    )

    upload_to_app_store(
      api_key: api_key,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  # Run snapshots tests locally first to avoid having translucent buttons being wrongly rendered
  desc "Frame already existing screenshots"
  lane :frame_le_screenshots do
    frameit(
      path: "./fastlane/screenshots"
    )
  end

  desc "Upload screenshots to App Store Connect"
  lane :upload_screenshots do
    upload_to_app_store(
      api_key: api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      screenshots_path: "./fastlane/screenshots"
    )
  end

  desc "Upload metadata only to App Store Connect"
  lane :upload_metadata do
    upload_to_app_store(
      api_key: api_key,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: true,
      force: true,
      verbose: true
    )
  end

  desc "Verify metadata without uploading"
  lane :verify_metadata do
    precheck(
      api_key: api_key,
      include_in_app_purchases: false
    )
  end
end

lane :lint do
  Dir.chdir("..") do
    sh "swiftlint lint --strict"
  end
end
